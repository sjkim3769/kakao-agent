# ============================================================
# KakaoTalk Agent - 환경 설정
# [Quality] 실제 시크릿은 .env에 보관, 이 파일은 git commit 안함
# ============================================================

# --- 데이터베이스 ---
DATABASE_URL=postgresql://kakao_agent:your_password@localhost:5432/kakao_agent
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=5

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# --- Groq API ---
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=1000
LLM_TIMEOUT_SECONDS=30

# --- 스케줄러 ---
COLLECT_CRON_HOUR=2        # 오전 2시 수집/분석
COLLECT_CRON_MINUTE=0
AGENT_CRON_HOUR=9          # 오전 9시 댓글 발송
AGENT_CRON_MINUTE=0
TIMEZONE=Asia/Seoul

# --- 데이터 디렉토리 ---
DATA_DIR=/data/kakao_exports
LOG_DIR=/var/log/kakao-agent

# --- 대화방 설정 ---
# 쉼표로 구분된 대화방 ID 목록
ROOM_IDS=room_001,room_002

# --- 품질 제어 ---
COMMENT_AUTO_APPROVE=true
COMMENT_MIN_LENGTH=50
COMMENT_MAX_LENGTH=500

# --- 보안 ---
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- 개발 모드 ---
DEBUG=false
LOG_LEVEL=INFO
